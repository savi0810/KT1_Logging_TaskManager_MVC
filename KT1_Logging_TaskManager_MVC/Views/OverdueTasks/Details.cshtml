@model KT1_Logging_TaskManager_MVC.Models.OverdueTasks

@{
    ViewData["Title"] = "Overdue Task Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-warning-light">
                <div class="card-header bg-white border-bottom border-warning-light">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 text-warning d-flex align-items-center">
                            <i class="fas fa-clock me-2"></i>Overdue Task Details
                        </h4>
                        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">
                            <i class="fas fa-arrow-left me-1"></i>Back
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    <div class="mb-4">
                        <h5 class="fw-bold mb-2">@Model.TaskName</h5>
                        <span class="badge bg-warning text-dark task-badge">Overdue</span>
                    </div>

                    <div class="mb-4">
                        <h6 class="fw-bold text-warning mb-2">Description</h6>
                        <p class="task-description">
                            @if (!string.IsNullOrEmpty(Model.TaskDescription))
                            {
                                @Model.TaskDescription
                            }
                            else
                            {
                                <span class="text-muted">No description provided</span>
                            }
                        </p>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <h6 class="fw-bold text-warning mb-2">Overdue Since</h6>
                            <p class="task-meta">
                                <i class="fas fa-clock me-2"></i>
                                @Model.WhenOverdueDate.ToString("MMMM dd, yyyy")
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>