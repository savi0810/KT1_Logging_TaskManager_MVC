@model IEnumerable<KT1_Logging_TaskManager_MVC.Models.CurrentTasks>

@{
    ViewData["Title"] = "Current Tasks";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="page-title">Current Tasks</h1>
        <a class="btn btn-purple btn-lg d-flex align-items-center" asp-action="Create">
            <i class="fas fa-plus me-2"></i>New Task
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-purple-light">
            <div class="card-body text-center py-5">
                <i class="fas fa-clipboard-list fa-3x text-purple empty-state-icon"></i>
                <h3 class="text-muted mt-3">No tasks found</h3>
                <p class="text-muted mb-4">Start to create your first task!</p>
            </div>
        </div>
    }
    else
    {
        <div class="tasks-grid fade-in">
            @foreach (var task in Model)
            {
                <div class="card task-card shadow-sm">
                    @{
                        string statusClass = "status-green";
                        if (task.DueDate.HasValue)
                        {
                            var daysLeft = (task.DueDate.Value - DateTime.Now).Days;
                            if (daysLeft <= 1) statusClass = "status-red";
                            else if (daysLeft <= 3) statusClass = "status-yellow";
                        }
                    }
                    <div class="task-status-indicator @statusClass"></div>

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title">@task.TaskName</h5>
                            @if (task.Priority == "High")
                            {
                                <span class="badge bg-danger task-badge">High</span>
                            }
                            else if (task.Priority == "Medium")
                            {
                                <span class="badge bg-warning text-dark task-badge">Medium</span>
                            }
                            else
                            {
                                <span class="badge bg-success task-badge">Low</span>
                            }
                        </div>

                        @if (task.DueDate.HasValue)
                        {
                            <div class="task-meta mb-3">
                                <i class="fas fa-calendar-alt me-2 text-purple"></i>
                                Due: @task.DueDate.Value.ToString("MMM dd, yyyy")
                            </div>
                        }

                        <p class="task-description mb-4">
                            @if (!string.IsNullOrEmpty(task.TaskDescription))
                            {
                                @(task.TaskDescription.Length > 120 ? task.TaskDescription.Substring(0, 120) + "..." : task.TaskDescription)
                            }
                            else
                            {
                                <span class="text-muted">No description provided</span>
                            }
                        </p>

                        <div class="task-actions">
                            <form asp-action="Complete" asp-route-id="@task.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-complete action-btn"
                                        title="Mark as Completed">
                                    <i class="fas fa-check"></i>
                                </button>
                            </form>

                            <a class="btn btn-view action-btn" asp-action="Details" asp-route-id="@task.Id" title="View Details">
                                <i class="fas fa-eye"></i>
                            </a>

                            <a class="btn btn-edit action-btn" asp-action="Edit" asp-route-id="@task.Id" title="Edit Task">
                                <i class="fas fa-edit"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@task.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-delete action-btn"
                                        onclick="return confirm('Are you sure you want to delete this task?')"
                                        title="Delete Task">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>