@model KT1_Logging_TaskManager_MVC.Models.CurrentTasks

@{
    ViewData["Title"] = "Edit Task";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-purple-light">
                <div class="card-header bg-white border-bottom border-purple-light">
                    <h4 class="mb-0 text-purple d-flex align-items-center">
                        <i class="fas fa-edit me-2"></i>Edit Task
                    </h4>
                </div>

                <div class="card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="TaskName" class="form-label fw-bold">Task Title *</label>
                            <input asp-for="TaskName" class="form-control" />
                            <span asp-validation-for="TaskName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TaskDescription" class="form-label fw-bold">Description</label>
                            <textarea asp-for="TaskDescription" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="TaskDescription" class="text-danger small"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DueDate" class="form-label fw-bold">Due Date</label>
                                <input asp-for="DueDate" type="date" class="form-control" />
                                <span asp-validation-for="DueDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Priority" class="form-label fw-bold">Priority</label>
                                <select asp-for="Priority" class="form-select">
                                    <option value="Low">Low</option>
                                    <option value="Medium">Medium</option>
                                    <option value="High">High</option>
                                </select>
                                <span asp-validation-for="Priority" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end">
                            <a class="btn btn-outline-secondary me-3" asp-action="Index">
                                <i class="fas fa-arrow-left me-1"></i>Back to List
                            </a>
                            <button type="submit" class="btn btn-purple">
                                <i class="fas fa-save me-1"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}