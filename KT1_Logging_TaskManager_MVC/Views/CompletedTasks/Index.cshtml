@model IEnumerable<KT1_Logging_TaskManager_MVC.Models.CompletedTasks>

@{
    ViewData["Title"] = "Completed Tasks";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="page-title">Completed Tasks</h1>
        <form asp-action="ClearAll" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-lg d-flex align-items-center"
                    onclick="return confirm('Are you sure you want to delete ALL completed tasks? This action cannot be undone!')">
                <i class="fas fa-broom me-2"></i>Clear All
            </button>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-success-light">
            <div class="card-body text-center py-5">
                <i class="fas fa-check-circle fa-3x text-success empty-state-icon"></i>
                <h3 class="text-muted mt-3">No completed tasks</h3>
                <p class="text-muted mb-4">Your completed tasks will appear here</p>
                <a class="btn btn-outline-success mt-3" asp-controller="CurrentTasks" asp-action="Index">
                    <i class="fas fa-arrow-left me-2"></i>Back to Current Tasks
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="tasks-grid fade-in">
            @foreach (var task in Model)
            {
                <div class="card task-card shadow-sm border-success-light">
                    <div class="task-status-indicator status-green"></div>

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title">@task.TaskName</h5>
                            <span class="badge bg-success task-badge">Completed</span>
                        </div>

                        <div class="task-meta mb-3">
                            <i class="fas fa-check-circle me-2 text-success"></i>
                            Completed: @task.CompletedDate.ToString("MMM dd, yyyy")
                        </div>

                        <p class="task-description mb-4">
                            @if (!string.IsNullOrEmpty(task.TaskDescription))
                            {
                                @(task.TaskDescription.Length > 120 ? task.TaskDescription.Substring(0, 120) + "..." : task.TaskDescription)
                            }
                            else
                            {
                                <span class="text-muted">No description provided</span>
                            }
                        </p>

                        <div class="task-actions">
                            <a class="btn btn-view action-btn me-2" asp-action="Details" asp-route-id="@task.Id" title="View Details">
                                <i class="fas fa-eye"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@task.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-delete action-btn"
                                        onclick="return confirm('Are you sure you want to delete this completed task?')"
                                        title="Delete Task">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>